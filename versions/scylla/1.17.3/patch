+func TestTableMetadataAfterKeyspaceInvalidation(t *testing.T) {
+	t.Parallel()
+
+	ctrl := &schemaDataMock{
+		knownKeyspaces: map[string][]tableInfo{
+			"test_ks": {
+				{name: "tbl_a", columns: []columnInfo{{name: "id", kind: "partition_key", position: 0}}},
