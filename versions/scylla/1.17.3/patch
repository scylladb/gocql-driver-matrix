+	}
+	if tbl.Name != "tbl_a" {
+		t.Fatalf("expected table name tbl_a, got %s", tbl.Name)
+	}
+	// Verify that a refresh query was issued (keyspace was reloaded)
+	if ctrl.getQueryCount() == 0 {
+		t.Fatal("expected queries to reload keyspace after invalidation")
+	}
+}
